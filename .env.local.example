# Copie ce fichier en .env.local (jamais commité, voir .gitignore) et remplis les valeurs
# depuis le dashboard de ton projet Supabase : Project Settings > API Keys.
#
# Sur un projet créé récemment, l'onglet "API Keys" affiche des clés "Publishable"
# et "Secret" (nouveau système Supabase) plutôt que "anon"/"service_role" (ancien
# système, en cours de retrait). C'est la clé "Secret" (sb_secret_...) qu'il faut
# mettre ici — elle joue exactement le rôle de l'ancienne service_role.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Clé "Publishable" (sb_publishable_..., équivalent de l'ancienne clé "anon") —
# utilisée uniquement côté serveur (Server Actions/middleware) pour la session
# Auth des Organisateurs (Story 3.1). Volontairement SANS préfixe NEXT_PUBLIC_ :
# ce produit ne construit aucun client Supabase navigateur, donc rien ne
# justifie de l'exposer au bundle client (voir Dev Notes, Story 3.1).
SUPABASE_PUBLISHABLE_KEY=

# Emails des deux comptes Organisateur provisionnés à la main dans le
# dashboard Supabase (Authentication > Users, Task 5 de la Story 3.1),
# séparés par une virgule. Supabase Auth n'a pas de notion de "rôle" pour un
# compte email/mot de passe simple — cette allowlist est ce qui distingue
# "un utilisateur Supabase authentifié" de "un des deux Organisateurs".
# Exemple : ORGANISATEUR_EMAILS=charles@example.com,basile@example.com
ORGANISATEUR_EMAILS=

# Notification Telegram (Story 3.4, AD-7). Token du bot créé via @BotFather
# (commande /newbot) — à traiter comme un secret, jamais commité ni partagé
# au-delà des deux Organisateurs/développeurs.
TELEGRAM_BOT_TOKEN=

# chat_id numérique de chaque Organisateur (Charles, Basile), séparés par une
# virgule — même convention que ORGANISATEUR_EMAILS. Récupéré en envoyant un
# message au bot puis en appelant https://api.telegram.org/bot<TOKEN>/getUpdates
# (voir "chat":{"id":...} dans la réponse).
# Exemple : TELEGRAM_CHAT_IDS=443474022,987654321
TELEGRAM_CHAT_IDS=

# Optionnel : domaine de production, sans slash final, utilisé pour inclure un
# lien direct vers la conversation dans la notification Telegram (ex.
# https://laparoleavanttout.example). Si absent, la notification est envoyée
# sans lien — jamais bloquant (Story 3.4).
SITE_URL=

# Secret partagé avec Vercel Cron (Story 3.5, relance à 4h). Vercel envoie
# automatiquement cette valeur dans l'en-tête Authorization: Bearer <CRON_SECRET>
# à chaque déclenchement planifié de /api/cron/relance — permet à la route de
# refuser tout appel qui ne vient pas de l'infrastructure Vercel Cron. Générer
# une chaîne aléatoire d'au moins 16 caractères (ex. générateur de mot de passe)
# et la renseigner à l'identique ici et dans les Environment Variables du
# projet Vercel (Production).
CRON_SECRET=
